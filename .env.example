# Copy to .env and fill in. Phase-1 runs without any of these (fixtures only).
# KAP has no documented public API — kap-client wraps internal endpoints, no key needed.

# GLEIF REST API (no key required for LEI lookups; here for rate-limit identification)
GLEIF_USER_AGENT="turkish-markets-kg/0.1 (info@arteklab.com)"

# EVDS (TCMB macro series) — Phase 2. Register at evds3.tcmb.gov.tr for a key
# (the old evds2 host now 302-redirects to evds3; REST contract under migration).
EVDS_API_KEY=

# LLM extraction (Phase 3) — KAP filing -> graph edges
ANTHROPIC_API_KEY=

# Where the Kuzu database directory lives (relative to repo root)
TMKG_DB_PATH=./data/tmkg.kuzu

# Where raw KAP documents are cached (re-run extraction without re-hitting KAP)
TMKG_RAW_DOCS_PATH=./data/raw_docs

# --- Matriks (v2 data spine) — REST + header-auth MCP (see Matriks_MCP_Dokumani.pdf) ---
# REST (ingestion): X-API-Key: <username>:<key>, X-Client-ID: <username or client_id>
# Header-auth MCP (interactive agent): MATRIKS_MCP_URL with X-Client-ID + X-API-Key.
MATRIKS_USERNAME=        # 5-digit Matriks portal username (also the REST X-API-Key prefix)
MATRIKS_CLIENT_ID=       # OAuth Client ID (alt X-Client-ID; username also works)
MATRIKS_API_KEY=         # sk_live_... (key alone)
MATRIKS_MCP_URL=https://mcp.matriks.ai/mcp
MATRIKS_REST_URL=https://mcp.matriks.ai/mcp-api/v1
